# AI Job Scout Configuration
# Copy this to .env and fill in your values

# ===========================================
# AI PROVIDERS (at least one required)
# ===========================================

# Anthropic Claude (Recommended - best for complex analysis)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT (Alternative)
OPENAI_API_KEY=sk-...

# OpenCode Proxy (Local models via proxy)
OPENCODE_BASE_URL=http://localhost:4001

# ===========================================
# ACTIVE PROVIDER
# ===========================================
# Options: anthropic, openai, opencode
ACTIVE_PROVIDER=anthropic

# ===========================================
# JOB SCRAPING (optional credentials)
# ===========================================

# LinkedIn (if using LinkedIn scraper)
# LINKEDIN_EMAIL=your@email.com
# LINKEDIN_PASSWORD=yourpassword

# ===========================================
# SEARCH DEFAULTS
# ===========================================
DEFAULT_LOCATION="Dubai, UAE"
MAX_RESULTS=20
